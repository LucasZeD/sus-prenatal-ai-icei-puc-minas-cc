// ============================================================
// schema.prisma — Conecte Mãe | SUS Pré-natal AI
// Prisma V7 — datasource gerenciado via prisma.config.ts
// LGPD: nome real armazenado, PII protegida por guardrails
//        na camada de aplicação (/src/lib/anonymizer).
//        Transcrição bruta NUNCA é persistida.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

// Prisma V7: URL gerenciada exclusivamente via prisma.config.ts
// NÃO declarar `url` aqui — breaking change do V7.
datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Raca {
  BRANCA
  PRETA
  PARDA
  AMARELA
  INDIGENA
  NAO_INFORMADO
}

enum RiscoGestacional {
  NORMAL
  ALTO
  MUITO_ALTO
}

/// Ciclo de vida de uma Consulta (workflow Human-in-the-Loop)
enum StatusConsulta {
  RASCUNHO             // Consulta criada, não iniciada
  EM_ANDAMENTO         // Escriba Digital ativo (áudio capturado)
  AGUARDANDO_CONFIRMACAO // IA extraiu dados, aguarda revisão da enfermeira
  CONFIRMADA           // Enfermeira confirmou/editou e salvou
}

// ============================================================
// MODEL: Profissional de Saúde
// Auth simples para MVP — email + senha_hash (bcrypt)
// ============================================================

model Profissional {
  id           String     @id @default(cuid())
  nome         String
  email        String     @unique
  senha_hash   String     // bcrypt — NUNCA expor via API
  crm_coren    String?    // Registro profissional (CRM ou COREN)
  cargo        String?    // Ex: "Enfermeira Obstetra", "Médico PSF"
  foto_url     String?

  pacientes    Paciente[]

  data_criacao DateTime   @default(now())
  data_update  DateTime   @updatedAt

  @@map("profissionais")
}

// ============================================================
// MODEL: Paciente (Gestante)
// LGPD: nome_real armazenado, protegido por guardrails
//        na camada de aplicação. Cartão SUS e NIS ficam
//        como hash para evitar exposição em dumps acidentais.
// ============================================================

model Paciente {
  id               String           @id @default(cuid())

  // --- Identidade ---
  nome_real        String           // Protegido por guardrails — não logar
  nome_preferido   String?          // "Como prefiro ser chamada"
  nome_companheiro String?

  // --- Documentos SUS (hash bcrypt — não reversíveis) ---
  cartao_sus_hash    String?  @unique // Hash do Cartão Nacional de Saúde
  num_sisprenatal    String?          // Número SISPRENATAL (pode ser nulo no cadastro inicial)
  num_nis_hash       String?          // Hash do NIS/PIS

  // --- Dados Pessoais ---
  data_nascimento    DateTime?
  raca               Raca             @default(NAO_INFORMADO)
  trabalha_fora_casa Boolean          @default(false)
  ocupacao           String?

  // --- Endereço ---
  endereco           String?
  ponto_referencia   String?
  cep                String?
  cidade             String?
  estado             String?          // UF (2 letras)

  // --- Dados Obstétricos Iniciais (primeira consulta) ---
  ig_inicial_semanas Int?             // Idade gestacional na 1ª consulta (semanas)
  imc_pre_gestacional Float?          // IMC pré-gestacional

  // --- Risco Calculado (atualizado pela IA a cada consulta) ---
  risco_atual      RiscoGestacional @default(NORMAL)

  // --- Relacionamentos ---
  profissional_id  String
  profissional     Profissional     @relation(fields: [profissional_id], references: [id])
  consultas        Consulta[]
  exames           Exame[]

  // --- Auditoria ---
  data_cadastro    DateTime         @default(now())
  data_update      DateTime         @updatedAt

  @@map("pacientes")
}

// ============================================================
// MODEL: Consulta de Pré-Natal
// Espelha os campos da Caderneta da Gestante SUS 8ª Edição.
// Transcrição bruta do Escriba NUNCA é salva aqui.
// Apenas o resultado estruturado após confirmação da enfermeira.
// ============================================================

model Consulta {
  id               String          @id @default(cuid())
  paciente_id      String
  numero_consulta  Int             // Número sequencial: 1ª, 2ª, 3ª...

  // --- Ciclo de Vida ---
  status           StatusConsulta  @default(RASCUNHO)

  // --- Data da Consulta ---
  data_consulta    DateTime?

  // --- Campos Clínicos Gerais ---
  queixa                    String?   // Queixa principal
  peso_kg                   Float?
  edema                     String?   // Ex: "Não", "+", "++", "+++"
  apresentacao_fetal        String?   // Ex: "Cefálico", "Pélvico"
  toque                     String?   // Descrição do exame de toque
  exantema                  String?   // Descrição do exantema

  // --- Dados Obstétricos (por consulta) ---
  ig_semanas_dum_usg        String?   // Ex: "13s/3d" (IG por DUM ou USG)
  pressao_arterial          String?   // Ex: "110/70 mmHg"
  altura_uterina_cm         Int?
  bcf_mov_fetal             String?   // Ex: "150 bpm/t" (BCF e movimentação)

  // --- Atividades Educativas ---
  participou_atividades     Boolean   @default(false)
  data_atividade_1          DateTime?
  data_atividade_2          DateTime?
  data_atividade_3          DateTime?

  // --- Visita à Maternidade ---
  realizou_visita_maternidade Boolean  @default(false)
  data_visita_maternidade     DateTime?

  // --- Planejamento Familiar ---
  deseja_diu_pos_parto      Boolean?

  // --- IA (Escriba + LívIA) ---
  // transcricao_bruta: CAMPO INTENCIONALMENTE AUSENTE (LGPD)
  // Apenas o resultado estruturado e aprovado é salvo.
  conduta_ia                String?   // Sugestão gerada pela LívIA (RAG)
  risco_calculado           RiscoGestacional @default(NORMAL)

  // --- Human-in-the-Loop ---
  validacao_medica          Boolean   @default(false) // true = enfermeira confirmou

  // --- Conduta Médica Final (pós-confirmação) ---
  observacoes_diagnostico_conduta String?

  // --- Agendamento Próxima Consulta ---
  proxima_consulta_data     DateTime?

  // --- Relacionamento ---
  paciente                  Paciente  @relation(fields: [paciente_id], references: [id], onDelete: Cascade)

  // --- Auditoria ---
  data_criacao              DateTime  @default(now())
  data_update               DateTime  @updatedAt

  @@unique([paciente_id, numero_consulta]) // Garante sequência única por paciente
  @@map("consultas")
}

// ============================================================
// MODEL: Exame Laboratorial
// resultado_criptografado: criptografia a nível de aplicação
// (não deixar em plaintext no banco).
// ============================================================

model Exame {
  id                      String   @id @default(cuid())
  paciente_id             String
  tipo                    String   // Ex: "Hemograma", "VDRL", "Toxoplasmose"
  data                    DateTime @default(now())
  resultado_criptografado String   // AES-256 via /src/lib/crypto

  paciente                Paciente @relation(fields: [paciente_id], references: [id], onDelete: Cascade)

  @@map("exames")
}