# Copie para `.env` na pasta Codigo/ e ajuste os valores.
# Nunca commite `.env` com segredos reais.

NODE_ENV=development

# Postgres (serviço `db` no Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sus_prenatal

# Postgres publicado em 127.0.0.1:<porta> (host) para Prisma local / ferramentas
POSTGRES_HOST_PORT=5432

# Backend (Hono)
BACKEND_PUBLISH_PORT=3000
BACKEND_PORT=3000

# Proteção básica contra excesso de chamadas ao backend.
# API_RATE_LIMIT_* vale para /api/v1 em geral; AI_RATE_LIMIT_* é mais restritivo para rotas de IA/RAG/MCP.
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20
# Limites de concorrência para chamadas externas pesadas (rejeita com 429 quando saturado; não cria fila em memória).
# Demo single-GPU: LLM=1 e CLINICAL_AI_PROXY=2 mantêm uma chamada ativa + uma esperando o slot interno do Ollama;
# a 3ª recebe 429 com `code: "clinical_ai_proxy_busy"`/`"llm_busy"`. Combine com `OLLAMA_NUM_PARALLEL=1` no host.
SANITIZE_CONCURRENCY_LIMIT=4
LLM_CONCURRENCY_LIMIT=1
STT_CONCURRENCY_LIMIT=2
CLINICAL_AI_PROXY_CONCURRENCY_LIMIT=2

# URL usada pelo Prisma no host (dev local). DEVE usar o mesmo POSTGRES_USER e POSTGRES_PASSWORD
# deste arquivo (não use literais "USUARIO:SENHA" — isso gera P1000 no `prisma migrate`).
# O backend carrega `backend/.env` e depois este arquivo com override: valores aqui prevalecem.
DATABASE_URL=postgresql://postgres:change_me_strong_password@127.0.0.1:5432/sus_prenatal

# CORS: origens permitidas (separadas por vírgula). Ex.: dev no celular com Vite:
# FRONTEND_ORIGIN=http://localhost:5173,http://192.168.0.10:5173
FRONTEND_ORIGIN=http://localhost:5173

# Build do frontend no Docker: use "/" para API no mesmo host (nginx → backend); login no celular na LAN funciona.
# Dev só Vite no PC: http://127.0.0.1:3000 | Vite no celular (--host): http://IP_DO_PC:3000
VITE_API_BASE_URL=/
FRONTEND_PUBLISH_PORT=5173

# Dev local do frontend (Vite): copie `frontend/.env.example` para `frontend/.env`

# Sidecar MCP (vazio = gateway noop no backend). Pode apontar para o clinical_ai: `http://clinical_ai:4010` (Compose) se expuser `POST /mcp/sanitize`.
MCP_SERVER_URL=

# Serviço FastAPI RAG + contexto (clinical-ai).
# Compose (backend no Docker): omita esta linha ou use `http://clinical_ai:4010` — `localhost` no container aponta para o próprio backend.
# Backend no host (npm): `CLINICAL_AI_URL=http://127.0.0.1:4010`
CLINICAL_AI_URL=
CLINICAL_AI_PUBLISH_PORT=
CLINICAL_AI_OLLAMA_BASE_URL=
# clinical-ai (FastAPI): raciocínio estendido no POST /api/chat quando think não é enviado no JSON (modelos compatíveis).
OLLAMA_THINK=false
# num_predict (Ollama) para /mcp/test/direct-question*. Com Think=ON: min(MCP_CHAT_THINK_MAX_PREDICT, max(MCP_CHAT_MAX_TOKENS+EXTRA, PISO)).
MCP_CHAT_MAX_TOKENS=4096
MCP_CHAT_THINK_EXTRA_TOKENS=2048
MCP_CHAT_THINK_NUM_PREDICT_FLOOR=2048
MCP_CHAT_THINK_MAX_PREDICT=8192
# Opcional — apenas no serviço clinical-ai (nuvem). Usado quando llm_provider=gemini ou auto com Ollama indisponível.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_S=120
# Modelo de embedding no Ollama
RAG_EMBEDDING_MODEL=
# clinical-ai corpus: pasta com cartilhas (.md/.txt/.pdf/.docx ou .jsonl). Compose default: /app/corpus/CartilhasSUS
RAG_CORPUS_DIR=
# SQLite com vetores pré-calculados (persistência entre reinícios).
RAG_VECTOR_STORE_PATH=
# 1/true ignora SQLite e sempre re-incorpora
RAG_DISABLE_VECTOR_STORE=
# Depois do build opcionalmente grava snapshots JSONL (chunks) para auditoria
RAG_EXPORT_CHUNKS_JSONL=
RAG_RECENCY_WEIGHT=0.35
# Tamanho dos chunks na indexação (após mudar, faça rebuild do índice RAG com force=true)
RAG_CHUNK_MAX_CHARS=1650
RAG_CHUNK_OVERLAP=120
# Ollama gera termos de busca a partir da pergunta antes do embedding (melhora relevância; exige modelo acessível). Compose default: true
RAG_QUERY_EXPAND_ENABLED=true
RAG_QUERY_EXPAND_MAX_TOKENS=220
RAG_QUERY_EXPAND_MAX_OUT_CHARS=450

# Streaming consulta — STT / LLM (opcionais; vazio = stubs sem rede externa)
WHISPER_HTTP_URL=
OLLAMA_HTTP_URL=
OLLAMA_MODEL=qwen3.5:9b-medical-rag
# Debounce (ms) antes de disparar RAG sem pontuação final; mínimo de caracteres no trecho
STREAM_RAG_DEBOUNCE_MS=900
STREAM_RAG_MIN_CHARS=14

# Pepper (segredo) para HMAC dos hashes em `paciente_ids` — obrigatório para cadastro de paciente com CPF/Cartão (anti-duplicidade / homônimo).
# Em dev pode ser um valor longo fixo local; em produção use segredo gerenciado (vault/KMS).
PACIENTE_IDS_PEPPER=change_me_long_random_pepper_for_hmac_only

# RF14 — JWT (HS256). Mínimo 32 caracteres; obrigatório para `docker compose` subir o `backend`.
JWT_SECRET=change_me_jwt_secret_at_least_32_characters_long
JWT_EXPIRES_SEC=28800

# Profissional para login (RF14). O seed (`npm run db:seed` em `backend/` ou após `prisma migrate reset`)
# lê este arquivo (Codigo/.env). Se EMAIL e PASSWORD estiverem vazios e DATABASE_URL for localhost,
# o seed usa admin@local.dev / changeme_seed_password automaticamente.
SEED_PROFISSIONAL_EMAIL=admin@local.dev
SEED_PROFISSIONAL_PASSWORD=changeme_seed_password
SEED_PROFISSIONAL_NOME=Administrador local

# Dev Sandbox — criar outros profissionais via POST /api/v1/dev/profissionais (requer JWT).
# Desligado por padrão. Com =1, só e-mails listados em DEV_ADMIN_EMAILS podem criar; se DEV_ADMIN_EMAILS vazio, vale só SEED_PROFISSIONAL_EMAIL.
DEV_ALLOW_PROFISSIONAL_CREATE=0
DEV_ALLOW_SANDBOX_DB_DELETE=1
# Ex.: admin@local.dev,outro@empresa.com
DEV_ADMIN_EMAILS=